# ============================================================
# Variables de entorno para el envío de correo via Brevo SMTP
# ============================================================
# Copia este archivo como .env y completa con tus credenciales reales.
# NUNCA subas el archivo .env al repositorio (debe estar en .gitignore).

# Login SMTP de Brevo: es tu EMAIL de cuenta Brevo (no un alias)
# Ejemplo: micuenta@dominio.com
BREVO_SMTP_LOGIN=tu_email_de_cuenta_brevo@ejemplo.com

# API Key SMTP de Brevo: obtenla en app.brevo.com > SMTP & API > SMTP
# NO uses tu contraseña de Brevo, sino la clave SMTP generada allí.
# Ejemplo: xkeysib-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-xxxxxxxxxxx
BREVO_SMTP_KEY=tu_clave_smtp_de_brevo_aqui

# Dirección que aparece como remitente en los correos
# IMPORTANTE: debe estar verificada como "Sender" en Brevo
REMITENTE=geoportal.algarrobo@gmail.com

# Dirección de respuesta (Reply-To)
REPLY_TO=geoportal.algarrobo@gmail.com
